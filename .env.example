# Required for menu extraction and quality image generation (Gemini)
GOOGLE_API_KEY=your-google-api-key-here

# Required for fast image generation (Flux.1 Schnell via fal.ai)
FAL_KEY=your-fal-key-here

# Required for Grok image generation (xAI)
XAI_API_KEY=your-xai-api-key-here

# Required for GitHub Pages publishing
GITHUB_PAT=your-github-personal-access-token-here
GITHUB_OWNER=your-github-username
GITHUB_REPO=menus
